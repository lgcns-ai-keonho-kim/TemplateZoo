# 기본 런타임 설정
# 비워두면 local로 동작합니다.
ENV=

# 콘솔 로그 출력 (1=출력, 0=미출력)
LOG_STDOUT=1

# Gemini 실행 설정
GEMINI_MODEL=gemini-3.1-flash-lite-preview
GEMINI_PROJECT=
GEMINI_API_KEY=

# Agent 요청 제한 시간(초)
AGENT_REQUEST_TIMEOUT_SECONDS=180


# 선택: DB/엔진 통합 테스트 설정
# 아래 값은 기본 /agent 런타임이 자동으로 사용하지 않습니다.
# integrations 테스트나 수동 엔진 검증 시에만 사용합니다.

# PostgreSQL
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PW=postgres
POSTGRES_DATABASE=playground
# POSTGRES_DSN=postgresql://postgres:postgres@127.0.0.1:5432/playground
# PostgreSQL 벡터 테스트 활성화 (1이면 Vector 테스트 수행)
POSTGRES_ENABLE_VECTOR=0

# MongoDB
MONGODB_HOST=127.0.0.1
MONGODB_PORT=27017
MONGODB_USER=
MONGODB_PW=
MONGODB_DB=playground
MONGODB_AUTH_DB=
# MONGODB_URI=mongodb://127.0.0.1:27017

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PW=
# REDIS_URL=redis://127.0.0.1:6379/0

# Elasticsearch
ELASTICSEARCH_SCHEME=https
ELASTICSEARCH_HOST=127.0.0.1
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_USER=
ELASTICSEARCH_PW=
ELASTICSEARCH_CA_CERTS=
ELASTICSEARCH_VERIFY_CERTS=true
ELASTICSEARCH_SSL_FINGERPRINT=
# ELASTICSEARCH_HOSTS=https://127.0.0.1:9200

# SQLite 엔진 공통 옵션
SQLITE_BUSY_TIMEOUT_MS=5000
